# ===========================================================================
# StudyLogix — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# ---- Required in Production ----
# A cryptographically secure random string used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# ---- Optional ----
# Set to "production" to disable debug mode and enable secure cookies.
FLASK_ENV=development

# The port the app listens on (default: 5000).
PORT=5000
